      propertyPath: 'ArtifactDialogueLines.Array.data[0]'
      value: "A Gasera! You\u2019ve seen these old lamps before but never thought
        to actually see them this\u2026soggy. "
      objectReference: {fileID: 0}
    - target: {fileID: -2004419436851174541, guid: 53a67ac30f31e1b4f960a30d1fba2513, type: 3}
      propertyPath: 'ArtifactDialogueLines1.Array.data[0]'
